# Copy this file to `apps/web/.env.local` for local dev.
# Production: set the same variables on your host (e.g. Netlify → Site configuration → Environment variables).

# Supabase — Project Settings → API (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: required for /api/storage/logo and /api/storage/receipt signed redirects.
# Never expose this in the browser or client bundles.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URL — no trailing slash. Required for correct auth links on Netlify.
# Must appear in Supabase → Authentication → URL Configuration → Redirect URLs, e.g.:
#   https://YOUR_SITE.netlify.app/reset-password
#   https://YOUR_SITE.netlify.app/dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: secure cron for recurring invoices
# CRON_SECRET=long_random_string
